PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/aaply
CLIENT_ORIGIN=http://localhost:5173
GOOGLE_APPLICATION_CREDENTIALS=./src/config/gcp-key.json
VERTEX_PROJECT_ID=your_gcp_project_id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_MS=35000
JOB_DEBUG_ENABLED=true

# Comma-separated URLs. Use {query} placeholder for dynamic search keywords.
SCRAPE_TARGETS=https://www.amazon.jobs/en/search?base_query={query},https://careers.google.com/jobs/results/?q={query},https://jobs.careers.microsoft.com/global/en/search?q={query},https://www.metacareers.com/jobs/?q={query},https://www.ycombinator.com/jobs,https://wellfound.com/jobs,https://www.indeed.com/jobs?q={query},https://www.naukri.com/{query}-jobs,https://www.monsterindia.com/srp/results?query={query},https://www.linkedin.com/jobs/search/?keywords={query}
