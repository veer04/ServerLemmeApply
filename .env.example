PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/aaply
REDIS_URL=redis://username:password@host:6379
SESSION_DISPATCH_MODE=inline
SESSION_QUEUE_NAME=aaply-session-processing
SESSION_QUEUE_CONCURRENCY=2
SESSION_WORKER_ENABLED=false
# Single or comma-separated web origins allowed by CORS.
CLIENT_ORIGIN=https://app.example.com,https://preview-app.example.com
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
OTP_EXPIRY_MINUTES=5
SENDGRID_API_KEY=sendgrid_key_here
EMAIL_FROM=official.lemmeapply@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

GOOGLE_CLIENT_ID=your_google_web_client_id
# Do not commit key files. Set this to a secure runtime path or use Workload Identity.
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_PROJECT_ID=your_gcp_project_id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_MS=35000
JOB_DEBUG_ENABLED=false
RESUME_EXTRACT_TIMEOUT_MS=30000
RESUME_OCR_TIMEOUT_MS=45000
RESUME_OCR_ENABLED=true

# Comma-separated URLs. Use {query} placeholder for dynamic search keywords.
SCRAPE_TARGETS=https://www.amazon.jobs/en/search?base_query={query},https://careers.google.com/jobs/results/?q={query},https://jobs.careers.microsoft.com/global/en/search?q={query},https://www.metacareers.com/jobs/?q={query},https://www.ycombinator.com/jobs,https://wellfound.com/jobs,https://www.indeed.com/jobs?q={query},https://www.naukri.com/{query}-jobs,https://www.monsterindia.com/srp/results?query={query},https://www.linkedin.com/jobs/search/?keywords={query}
